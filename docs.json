{
  "$schema": "https://docs.page/schema.json",
  "name": "iopool Card",
  "description": "Documentation for the iopool card to use with iopool integration in Home Assistant",
  "logo": {
    "light": "https://brands.home-assistant.io/_/iopool/icon@2x.png"
  },
  "favicon": {
    "light": "https://brands.home-assistant.io/_/iopool/icon@2x.png"
  },
  "theme": {
    "defaultTheme": "dark",
    "primary": "#17817A",
    "primaryLight": "#43D1CD"
  },
  "tabs": [
    {
      "id": "root",
      "title": "Home",
      "href": "/"
    }
  ],
  "sidebar": [
    { "group": "Getting Started", "pages": ["introduction", "installation", "first-card"] },
    {
      "group": "Configuration",
      "pages": [
        "configuration/overview",
        "configuration/device",
        "configuration/pump",
        "configuration/thresholds",
        "configuration/chart",
        "configuration/actions"
      ]
    },
    {
      "group": "Components",
      "pages": [
        "components/header",
        "components/warning-banner",
        "components/liquid-gauge",
        "components/mode-selector",
        "components/pump-control",
        "components/filtration-progress",
        "components/boost-selector",
        "components/temperature-chart"
      ]
    },
    {
      "group": "Pool Modes",
      "pages": [
        "modes/standard",
        "modes/active-winter",
        "modes/passive-winter",
        "modes/maintenance"
      ]
    },
    {
      "group": "Troubleshooting",
      "pages": ["troubleshooting/debug-mode", "troubleshooting/common-issues"]
    }
  ],
  "social": {
    "github": "mguyard/hass-iopool-card"
  }
}
